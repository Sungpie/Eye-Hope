global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'spring-boot-local'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets: ['host.docker.internal:8080']

  - job_name: 'spring-boot-termux'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets: ['YOUR_SERVER_IP:8080']